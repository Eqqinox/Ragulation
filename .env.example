# Copy to .env and adjust for your local setup. Never commit the real .env file.

# Ollama server used for local embeddings and generation.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DENSE_MODEL_NAME=bge-m3

# Qdrant instance used as the hybrid vector store.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Mistral API key, only needed if a hosted generation model is used instead
# of a local Ollama model. Leave empty for the fully local configuration.
MISTRAL_API_KEY=
