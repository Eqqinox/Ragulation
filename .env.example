# Copy to .env and adjust for your local setup. Never commit the real .env file.

# Ollama server used for embeddings, generation, and the RAGAS judge.
# Locally, all three point at the same local Ollama server by default.
# The CI faithfulness gate instead points generation and the judge at
# Ollama Cloud (via the separate OLLAMA_GENERATION_*/OLLAMA_JUDGE_*
# vars below), since GitHub-hosted runners are CPU-only and unreliable
# for structured-output judging locally -- see ADR-0006. Embeddings
# stay local even in CI: Ollama Cloud's catalog has no embedding
# models.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DENSE_MODEL_NAME=bge-m3
OLLAMA_API_KEY=

# Overrides for generation and the judge specifically (used by CI to
# route only these two at Ollama Cloud, e.g.
# OLLAMA_GENERATION_BASE_URL=https://ollama.com plus a real
# OLLAMA_GENERATION_API_KEY/OLLAMA_JUDGE_API_KEY from
# ollama.com/settings/keys). Leave unset for local dev -- both default
# to the same local Ollama server as above.
OLLAMA_GENERATION_BASE_URL=
OLLAMA_GENERATION_API_KEY=
OLLAMA_JUDGE_BASE_URL=
OLLAMA_JUDGE_API_KEY=

# Qdrant instance used as the hybrid vector store.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
